+package ai.quickpose.reactnative
+
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.ReactApplicationContext
+import com.facebook.react.bridge.ReactContextBaseJavaModule
+import com.facebook.react.modules.core.DeviceEventManagerModule
+
+class QuickPoseEmitterModule(private val reactContext: ReactApplicationContext) :
+    ReactContextBaseJavaModule(reactContext) {
+
+    companion object {
+        const val NAME = "QuickPoseEmitter"
+        const val EVENT_NAME = "QuickPoseUpdate"
+
+        @Volatile
+        private var instance: QuickPoseEmitterModule? = null
+
+        fun emitUpdate(resultsJson: String, fps: Int) {
+            instance?.sendUpdate(resultsJson, fps)
+        }
+    }
+
+    init {
+        instance = this
+    }
+
+    override fun getName(): String = NAME
+
+    override fun invalidate() {
+        if (instance === this) {
+            instance = null
+        }
+        super.invalidate()
+    }
+
+    private fun sendUpdate(resultsJson: String, fps: Int) {
+        if (!reactContext.hasActiveReactInstance()) return
+
+        val params = Arguments.createMap().apply {
+            putString("resultsJson", resultsJson)
+            putInt("fps", fps)
+        }
+
+        reactContext
+            .getJSModule(DeviceEventManagerModule.RCTDeviceEventEmitter::class.java)
+            .emit(EVENT_NAME, params)
+    }
+}
